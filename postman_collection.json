      "item": [
        {
          "name": "API funcionando",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('API retorna mensagem de funcionamento', function () {",
                  "  pm.expect(pm.response.text()).to.include('API Studio Araujo Agenda');",
                  "});"
                ]
              }
            }
          ],
          "request": {
