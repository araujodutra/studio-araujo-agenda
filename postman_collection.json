    {
      "name": "01 - Autenticacao de Usuario",
      "item": [
        {
          "name": "Registrar novo usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 ou erro controlado se usuario ja existir', function () {",
                  "  pm.expect([201, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.test('Retorna mensagem e id do usuario', function () {",
                  "    pm.expect(json).to.have.property('mensagem');",
                  "    pm.expect(json).to.have.property('id');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"{{usuario}}\",\n  \"senha\": \"{{senha}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "register"
              ]
            },
            "description": "Cadastra um usuario usando src/controllers/authController.js."
          },
          "response": []
        },
        {
          "name": "Login do usuario e salvar token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Retorna token JWT', function () {",
                  "  pm.expect(json).to.have.property('token');",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"{{usuario}}\",\n  \"senha\": \"{{senha}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "login"
              ]
            },
            "description": "Realiza login e salva o JWT na variavel token da collection."
          },
          "response": []
        }
      ],
      "description": "User story: Como usuario do sistema, quero criar uma conta e fazer login para acessar rotas protegidas da agenda."
    },
    {
      "name": "02 - Cadastrar Cliente e Agendamento",
      "item": [
        {
          "name": "Criar cliente/agendamento",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Retorna mensagem e id do cliente', function () {",
                  "  pm.expect(json).to.have.property('mensagem');",
                  "  pm.expect(json).to.have.property('id');",
                  "});",
                  "",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('cliente_id', String(json.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Antonio\",\n  \"telefone\": \"61999999999\",\n  \"email\": \"teste@email.com\",\n  \"servico\": \"Limpeza\",\n  \"data_agendamento\": \"2026-04-30\",\n  \"horario\": \"14:00:00\",\n  \"observacoes\": \"Teste criado pelo Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/clientes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "clientes"
              ]
            },
            "description": "Cria cliente/agendamento. No codigo atual esta rota nao exige token, apenas validacao dos campos obrigatorios."
          },
          "response": []
        },
        {
          "name": "Criar cliente com dados obrigatorios ausentes",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Retorna erro de campos obrigatorios', function () {",
                  "  pm.expect(pm.response.json()).to.have.property('erro');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cliente sem horario\",\n  \"telefone\": \"61988888888\",\n  \"servico\": \"Corte\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/clientes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "clientes"
              ]
            },
            "description": "Cenario de erro da user story de cadastro: validar campos obrigatorios."
          },
          "response": []
        }
      ],
      "description": "User story: Como atendente, quero cadastrar um cliente com servico, data e horario para registrar um agendamento."
    },
    {
